# 小红书爆款标题助手 - 环境变量
# 复制为 .env 并填写

# LLM API（不填则使用内置模板生成）
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# 知识库目录（可选，默认 ./knowledge）
# KB_DIR=./knowledge

# 知识库编辑器密码（必填，否则编辑器不可用）
EDITOR_PASSWORD=change-me

# Flask session 密钥（可选，随机生成）
# SECRET_KEY=

# 服务端口
PORT=5088
